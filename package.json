{
  "name": "checks-your-actions",
  "version": "0.0.3",
  "description": "Know what CI will do before you push.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zshannon/checks-your-actions"
  },
  "type": "module",
  "files": [
    "dist/"
  ],
  "bin": {
    "cya": "dist/cli.js"
  },
  "scripts": {
    "build": "bun build src/cli.ts --outdir dist --target bun",
    "bump": "bumpp",
    "prepublishOnly": "bun run build",
    "format": "oxfmt --write src/ test/",
    "lint": "oxfmt --check src/ test/ && oxlint src/ test/",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/picomatch": "^4.0.2",
    "bumpp": "11.0.1",
    "oxfmt": "0.42.0",
    "oxlint": "1.57.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "citty": "^0.2.1",
    "consola": "^3.4.2",
    "picomatch": "^4.0.4",
    "yaml": "^2.8.3"
  }
}
